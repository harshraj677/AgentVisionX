# ── Backend (.env in /backend) ──────────────────────────
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# Optional: GROQ (free at console.groq.com) or OpenAI
GROQ_API_KEY=
OPENAI_API_KEY=

# ── Frontend (set in Vercel dashboard as env vars) ───────
# After deploying backend to Railway, paste its URL below:
VITE_API_BASE=https://your-railway-backend.up.railway.app
VITE_WS_URL=wss://your-railway-backend.up.railway.app/ws
